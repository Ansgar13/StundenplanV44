<Window x:Class="Stundenplan_V2.FixierenDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gezielt fixieren" Width="900" Height="660"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"
                   Text="Filter auswaehlen (Mehrfachauswahl mit Strg/Shift). Eine Zeile gilt als Treffer, wenn sie in IRGENDEINER der Listen einen Wert hat (ODER-Verknuepfung)."/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Aktion:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <RadioButton x:Name="RbFixieren"      Content="Treffer mit 'X' in Spalte 'Fix (X)' markieren"  GroupName="Aktion" IsChecked="True" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <RadioButton x:Name="RbNichtFixieren" Content="'X' aus Treffern entfernen"                     GroupName="Aktion" VerticalAlignment="Center"/>
        </StackPanel>

        <CheckBox Grid.Row="2" x:Name="ChkFixUNrn" Margin="0,0,0,8"
                  Content="Zusaetzlich: Treffer auch in Tabelle 'Fix UNrn' eintragen (bei 'X setzen') bzw. dort entfernen (bei 'X entfernen')"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Loesung als Quelle fuer Fix UNrn:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="CboLoesung" Width="220" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0" Text="Klassen" FontWeight="Bold" Margin="2"/>
            <ListBox  Grid.Column="0" Grid.Row="1" x:Name="LstKlassen" SelectionMode="Multiple" Margin="2"/>

            <TextBlock Grid.Column="1" Grid.Row="0" Text="Lehrer" FontWeight="Bold" Margin="2"/>
            <ListBox  Grid.Column="1" Grid.Row="1" x:Name="LstLehrer" SelectionMode="Multiple" Margin="2"/>

            <TextBlock Grid.Column="2" Grid.Row="0" Text="Faecher" FontWeight="Bold" Margin="2"/>
            <ListBox  Grid.Column="2" Grid.Row="1" x:Name="LstFaecher" SelectionMode="Multiple" Margin="2"/>

            <TextBlock Grid.Column="3" Grid.Row="0" Text="ZeilenText-2" FontWeight="Bold" Margin="2"/>
            <ListBox  Grid.Column="3" Grid.Row="1" x:Name="LstZeilentext2" SelectionMode="Multiple" Margin="2"/>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnOk"        Content="Ausfuehren" Width="100" Margin="0,0,5,0" Click="BtnOk_Click"        IsDefault="True"/>
            <Button x:Name="BtnAbbrechen" Content="Abbrechen"  Width="100"                Click="BtnAbbrechen_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
